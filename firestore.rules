rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------
    // Helper Functions
    // ---------------------------------------------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     * This is the foundation of the user ownership model.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the document being operated on already exists in Firestore.
     * CRITICAL for all update and delete operations.
     */
    function isExistingDoc() {
      return exists(resource.data);
    }

    /**
     * Combines owner and existence checks for secure updates and deletes.
     */
    // function isExistingOwner(userId) {
    //   return isOwner(userId) && isExistingDoc();
    // }
    
    /**
     * Retrieves the full user document for the given UID.
     * Note: This function incurs a read operation.
     */
    function getUser(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }
    
    /**
     * Retrieves the role of the currently authenticated user from their user profile.
     * Note: This function incurs a read operation.
     */
    function getUserRole() {
      return getUser(request.auth.uid).data.role;
    }

    /**
     * Checks if the currently authenticated user has the 'faculty' role.
     */
    function isFaculty() {
      return isSignedIn() && getUserRole() == 'faculty';
    }

    /**
     * Checks if the currently authenticated user has the 'admin' role.
     */
    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    /**
     * Checks if the currently authenticated user is either faculty or admin.
     */
    function isFacultyOrAdmin() {
      return isSignedIn() && (isAdmin() || isFaculty());
    }

    // ---------------------------------------------------------------------
    // Collection Rules
    // ---------------------------------------------------------------------

    match /users/{userId} {
      // Admins can manage any user doc, owners can manage their own.
      allow get, update, delete: if isOwner(userId) || isAdmin();
      allow list: if isFacultyOrAdmin();
      // Creating a user doc is still tied to the user signing up, but an admin could also do it.
      allow create: if (isOwner(userId) && request.resource.data.id == userId) || isAdmin();
    }

    match /courses/{courseId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isFacultyOrAdmin();
    }

    match /users/{userId}/enrollments/{enrollmentId} {
      allow get, list, update, delete: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.studentId == userId;
    }

    match /users/{userId}/attendance/{attendanceId} {
      allow get, list: if isOwner(userId) || isFacultyOrAdmin();
      allow create, update, delete: if isFacultyOrAdmin();
    }

    match /courses/{courseId}/timetables/{timetableId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isFacultyOrAdmin();
    }

    match /users/{userId}/results/{resultId} {
      allow get, list: if (isOwner(userId) && resource.data.published == true) || isFacultyOrAdmin();
      allow create, update, delete: if isFacultyOrAdmin();
    }

    match /courses/{courseId}/assignments/{assignmentId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isFacultyOrAdmin();

      match /submissions/{submissionId} {
        
        function isAssignmentFaculty() {
          let assignmentDoc = get(/databases/$(database)/documents/courses/$(courseId)/assignments/$(assignmentId));
          return isSignedIn() && assignmentDoc.data.facultyId == request.auth.uid;
        }

        allow get: if (isExistingDoc() && isOwner(resource.data.studentId)) || isAssignmentFaculty() || isAdmin();
        allow list: if isAssignmentFaculty() || isAdmin();
        
        allow create: if isSignedIn() 
                      && request.resource.data.studentId == request.auth.uid
                      && request.resource.data.assignmentId == assignmentId;
                      
        // Students can update their file/comments before grading. Faculty/Admins can update anything (for grading).
        allow update: if (isExistingDoc() && isOwner(resource.data.studentId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comments', 'fileUrl'])) 
                      || isAssignmentFaculty() || isAdmin();
        
        allow delete: if isOwner(resource.data.studentId);
      }
    }

    match /courses/{courseId}/study_materials/{studyMaterialId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isFacultyOrAdmin();
    }

    match /announcements/{announcementId} {
      allow get, list: if true;
      allow create, update, delete: if isFacultyOrAdmin() && request.resource.data.postedBy == request.auth.uid;
    }

    match /courses/{courseId}/forums/{forumId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isFacultyOrAdmin();

      match /forum_posts/{forumPostId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() 
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.userName == getUser(request.auth.uid).data.name;
        allow update, delete: if isExistingDoc() && isOwner(resource.data.userId);
      }
    }
    
    match /{path=**}/timetables/{timetableId} {
      allow read: if isSignedIn();
    }

    match /events/{eventId} {
      allow get, list: if true;
      allow create, update, delete: if isFacultyOrAdmin();
    }

    match /clubs/{clubId} {
      allow get, list: if isSignedIn();
      allow create, delete: if isFacultyOrAdmin();
      // Allow faculty/admins to update club details.
      // Allow students to update only the 'members' array to add themselves.
      allow update: if isFacultyOrAdmin() ||
                      (
                        isSignedIn() &&
                        // Check that only the 'members' field is being changed by the student.
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
                        // Check that the student is only adding their own UID to the array.
                        request.resource.data.members == resource.data.members.concat(request.auth.uid)
                      );
    }

    match /users/{userId}/notifications/{notificationId} {
      allow get, list, update, delete: if isOwner(userId);
      // Allow faculty or admins to create notifications for users.
      // This is used for generating personalized notifications.
      allow create: if isFacultyOrAdmin();
    }

    match /attendanceSessions/{sessionId} {
      // Faculty can create a new session if they are the one starting it.
      allow create: if isFaculty() && request.resource.data.facultyId == request.auth.uid;
      // The faculty who created the session can read it to monitor attendees.
      allow get: if isFaculty() && resource.data.facultyId == request.auth.uid;
      // Students can update the 'attendees' array to add themselves.
      // This rule ensures only the 'attendees' field is changed and only allows adding the current user's UID.
      allow update: if isSignedIn() 
                    && request.resource.data.keys().hasOnly(['attendees', 'courseId', 'facultyId', 'createdAt', 'id'])
                    && request.resource.data.attendees == resource.data.attendees.concat([request.auth.uid]);
      // No one can delete sessions or list all of them.
      allow delete, list: if false;
    }
  }
}
