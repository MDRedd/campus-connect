rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CampusConnect Security Rules
     * 
     * Core Philosophy:
     * This ruleset implements a hybrid security model combining Path-Based Ownership and 
     * Database-Backed Access Control (DBAC). Private student data (attendance, results, 
     * submissions) is secured via user-specific paths, while administrative and academic 
     * structures (departments, courses) are protected by user roles.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && userDocExists() && (getUserData().role == 'super-admin' || getUserData().role == 'user-admin' || getUserData().role == 'course-admin' || getUserData().role == 'attendance-admin');
    }

    function isFaculty() {
      return isSignedIn() && userDocExists() && getUserData().role == 'faculty';
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /enrollments/{enrollmentId} {
        allow get, list: if isOwner(userId) || isFaculty() || isAdmin();
        allow create: if (isOwner(userId) && request.resource.data.studentId == userId) || isAdmin();
        allow update: if (isExistingOwner(userId) && request.resource.data.studentId == userId) || isAdmin();
        allow delete: if isAdmin();
      }

      match /attendance/{attendanceId} {
        allow get, list: if isOwner(userId) || isFaculty() || isAdmin();
        allow create: if (isFaculty() || isAdmin()) && request.resource.data.studentId == userId;
        allow update: if (isFaculty() || isAdmin()) && resource != null && request.resource.data.studentId == userId;
        allow delete: if isAdmin();
      }

      match /results/{resultId} {
        allow get, list: if (isOwner(userId) && resource.data.published == true) || isFaculty() || isAdmin();
        allow create, update: if isFaculty() || isAdmin();
        allow delete: if isAdmin();
      }

      match /submissions/{submissionId} {
        allow get, list: if isOwner(userId) || isFaculty() || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.studentId == userId;
        allow update: if (isExistingOwner(userId) || isFaculty() || isAdmin()) && request.resource.data.studentId == userId;
        allow delete: if isExistingOwner(userId) || isAdmin();
      }

      match /notifications/{notificationId} {
        allow get, list: if isOwner(userId);
        allow create: if isAdmin() || isFaculty();
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }

      match /fees/{feeId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isAdmin();
      }
    }

    match /departments/{departmentId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /courses/{courseId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }
    }

    // Top-level courses collection used by catalog and results
    match /courses/{courseId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /timetables/{slotId} {
        allow get, list: if isSignedIn();
        allow create: if isAdmin() || (isFaculty() && request.resource.data.facultyId == request.auth.uid);
        allow update: if isAdmin() || (isFaculty() && resource.data.facultyId == request.auth.uid);
        allow delete: if isAdmin();
      }

      match /assignments/{assignmentId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isFaculty() || isAdmin();

        match /submissions/{submissionId} {
          allow get, list: if isSignedIn();
          allow create: if isOwner(request.resource.data.studentId);
          allow update: if isFaculty() || isAdmin();
        }
      }

      match /study_materials/{materialId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isFaculty() || isAdmin();
      }

      match /forums/{forumId} {
        allow get, list: if isSignedIn();
        allow create, update: if isFaculty() || isAdmin();
        allow delete: if isAdmin();

        match /forum_posts/{postId} {
          allow get, list: if isSignedIn();
          allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
          allow update, delete: if (resource != null && resource.data.userId == request.auth.uid) || isAdmin();
        }
      }
    }

    match /announcements/{announcementId} {
      allow get, list: if isSignedIn();
      allow create, update: if isFaculty() || isAdmin();
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /clubs/{clubId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isFaculty() && resource.data.facultyIncharge == request.auth.uid);
      allow delete: if isAdmin() || (isFaculty() && resource.data.facultyIncharge == request.auth.uid);
    }

    match /helpdeskTickets/{ticketId} {
      allow get, list: if isSignedIn() && (resource.data.studentId == request.auth.uid || isFaculty() || isAdmin());
      allow create: if isSignedIn();
      allow update: if isFaculty() || isAdmin();
    }

    match /communityPosts/{postId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (resource != null && resource.data.studentId == request.auth.uid);
    }

    match /correctionRequests/{requestId} {
      allow get, list: if isSignedIn() && (resource.data.studentId == request.auth.uid || isFaculty() || isAdmin());
      allow create: if isSignedIn();
      allow update: if isFaculty() || isAdmin();
    }

    match /attendanceSessions/{sessionId} {
      allow get, list: if isSignedIn();
      allow create: if isFaculty() || isAdmin();
      allow update: if isSignedIn();
    }

    // --- Collection Group Rules ---

    match /{path=**}/timetables/{slotId} {
      allow list: if isSignedIn();
    }

    match /{path=**}/attendance/{attendanceId} {
      allow list: if isFaculty() || isAdmin();
    }

    match /{path=**}/submissions/{submissionId} {
      allow list: if isFaculty() || isAdmin();
    }

    match /{path=**}/enrollments/{enrollmentId} {
      allow list: if isSignedIn();
    }

    match /{path=**}/results/{resultId} {
      allow list: if isSignedIn();
    }

    match /{path=**}/fees/{feeId} {
      allow list: if isAdmin();
    }

  }
}
