
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------
    // Helper Functions
    // ---------------------------------------------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     * This is the foundation of the user ownership model.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the document being operated on already exists in Firestore.
     * CRITICAL for all update and delete operations.
     */
    function isExistingDoc() {
      return exists(resource.data);
    }

    /**
     * Retrieves the full user document for the given UID.
     * Note: This function incurs a read operation.
     */
    function getUser(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }
    
    /**
     * Retrieves the role of the currently authenticated user from their user profile.
     * Note: This function incurs a read operation.
     */
    function getUserRole() {
      return getUser(request.auth.uid).data.role;
    }

    /**
     * Checks if the currently authenticated user has the 'faculty' role.
     */
    function isFaculty() {
      return isSignedIn() && getUserRole() == 'faculty';
    }

    /**
     * Checks if the user is a super-admin.
     */
    function isSuperAdmin() {
      return isSignedIn() && getUserRole() == 'super-admin';
    }

    /**
     * Checks if the user is a user-admin or super-admin.
     */
    function isUserAdmin() {
      let role = getUserRole();
      return isSignedIn() && (role == 'user-admin' || role == 'super-admin');
    }

    /**
     * Checks if the user is a course-admin or super-admin.
     */
    function isCourseAdmin() {
      let role = getUserRole();
      return isSignedIn() && (role == 'course-admin' || role == 'super-admin');
    }

    /**
     * Checks if the user is an attendance-admin or super-admin.
     */
    function isAttendanceAdmin() {
      let role = getUserRole();
      return isSignedIn() && (role == 'attendance-admin' || role == 'super-admin');
    }
    
    /**
     * Checks if the user has any type of admin role.
     */
    function isAnyAdmin() {
      return isSignedIn() && getUserRole().matches('.*-admin');
    }

    /**
     * Checks if the user is faculty or any type of admin.
     */
    function isFacultyOrAnyAdmin() {
        return isFaculty() || isAnyAdmin();
    }


    // ---------------------------------------------------------------------
    // Collection Rules
    // ---------------------------------------------------------------------

    match /users/{userId} {
      // User admins or super admins can manage any user doc, owners can manage their own.
      allow get, update: if isOwner(userId) || isUserAdmin();
      allow delete: if isUserAdmin(); // Only admins can delete user documents
      allow list: if isUserAdmin();
      // Creating a user doc is still tied to the user signing up, but an admin could also do it.
      allow create: if (isOwner(userId) && request.resource.data.id == userId) || isUserAdmin();
    }

    match /courses/{courseId} {
      // Allow anyone to see the list of courses (e.g., for a course catalog).
      allow list, get: if true;
      allow create, update, delete: if isCourseAdmin();
    }

    match /users/{userId}/enrollments/{enrollmentId} {
      allow get, list, update, delete: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.studentId == userId;
    }

    match /users/{userId}/attendance/{attendanceId} {
      allow get, list: if isOwner(userId) || isFaculty() || isAttendanceAdmin();
      // Ensure only the faculty who marked attendance or an admin can modify it.
      allow create: if (isFaculty() && request.resource.data.markedBy == request.auth.uid) || isAttendanceAdmin();
      allow update: if (isFaculty() && resource.data.markedBy == request.auth.uid) || isAttendanceAdmin();
      allow delete: if (isFaculty() && resource.data.markedBy == request.auth.uid) || isAttendanceAdmin();
    }

    match /courses/{courseId}/timetables/{timetableId} {
      allow get, list: if isSignedIn();
      allow create: if isCourseAdmin() || (isFaculty() && request.resource.data.facultyId == request.auth.uid);
      allow update, delete: if (isFaculty() && resource.data.facultyId == request.auth.uid) || isCourseAdmin();
    }

    match /users/{userId}/results/{resultId} {
      allow get, list: if (isOwner(userId) && resource.data.published == true) || isFaculty() || isCourseAdmin();
      allow create, update, delete: if isFaculty() || isCourseAdmin();
    }

    match /courses/{courseId}/assignments/{assignmentId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isFaculty() || isCourseAdmin();

      match /submissions/{submissionId} {
        
        function isAssignmentFaculty() {
          let assignmentDoc = get(/databases/$(database)/documents/courses/$(courseId)/assignments/$(assignmentId));
          return isSignedIn() && assignmentDoc.data.facultyId == request.auth.uid;
        }

        allow get: if (isExistingDoc() && isOwner(resource.data.studentId)) || isAssignmentFaculty() || isCourseAdmin();
        
        // Faculty/course-admins can list all submissions.
        // Students can list their own submission for a given assignment.
        allow list: if isAssignmentFaculty() || isCourseAdmin() || (isSignedIn() && request.query.where.studentId == request.auth.uid);
                      
        allow create: if isSignedIn() 
                      && request.resource.data.studentId == request.auth.uid
                      && request.resource.data.assignmentId == assignmentId;
                      
        // Students can update their file/comments before grading. Faculty/Admins can update anything (for grading).
        allow update: if (isExistingDoc() && isOwner(resource.data.studentId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comments', 'fileUrl'])) 
                      || isAssignmentFaculty() || isCourseAdmin();
        
        allow delete: if isOwner(resource.data.studentId);
      }
    }

    match /courses/{courseId}/study_materials/{studyMaterialId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isFaculty() || isCourseAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin() || (isFacultyOrAnyAdmin() && request.resource.data.postedBy == request.auth.uid);
    }

    match /courses/{courseId}/forums/{forumId} {
      function isForumCreator() {
        return resource.data.createdBy == request.auth.uid;
      }
      
      allow get, list: if isSignedIn();
      allow create: if (isFaculty() || isCourseAdmin()) && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if (isFaculty() && isForumCreator()) || isCourseAdmin();

      match /forum_posts/{forumPostId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() 
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.userName == getUser(request.auth.uid).data.name;
        allow update, delete: if isExistingDoc() && isOwner(resource.data.userId);
      }
    }
    
    match /{path=**}/timetables/{timetableId} {
      allow read: if isSignedIn();
    }

    match /events/{eventId} {
      allow get, list: if true;
      allow create, update, delete: if isFacultyOrAnyAdmin();
    }

    match /clubs/{clubId} {
      allow get, list: if isSignedIn();
      // Only super-admins can manage clubs
      allow create, update, delete: if isSuperAdmin();
      // Allow students to update only the 'members' array to add themselves.
      allow update: if isSuperAdmin() ||
                      (
                        isSignedIn() &&
                        // Check that only the 'members' field is being changed by the student.
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
                        // Check that the student is only adding their own UID to the array.
                        request.resource.data.members == resource.data.members.concat(request.auth.uid)
                      );
    }

    match /users/{userId}/notifications/{notificationId} {
      allow get, list, update, delete: if isOwner(userId);
      // Allow faculty or any admin to create notifications for users.
      allow create: if isFacultyOrAnyAdmin();
    }

    match /users/{userId}/fees/{feeId} {
      // Students can view their own fees.
      allow get, list: if isOwner(userId);
      // NOTE: For this prototype, students can update their own fee status to simulate payment.
      // In a production app, this would be handled by a secure backend function triggered by a payment provider.
      allow update: if isOwner(userId) || isAnyAdmin();
      // Only admins can create or delete fee records.
      allow create, delete: if isAnyAdmin();
    }

    match /attendanceSessions/{sessionId} {
      // Faculty can create a new session if they are the one starting it.
      allow create: if isFaculty() && request.resource.data.facultyId == request.auth.uid;
      // The faculty who created the session can read it to monitor attendees.
      allow get: if isFaculty() && resource.data.facultyId == request.auth.uid;
      // Students can update the 'attendees' array to add themselves.
      // This rule ensures only the 'attendees' field is changed and only allows adding the current user's UID.
      allow update: if isSignedIn() 
                    && request.resource.data.keys().hasOnly(['attendees', 'courseId', 'facultyId', 'createdAt', 'id'])
                    && request.resource.data.attendees == resource.data.attendees.concat([request.auth.uid]);
      // No one can delete sessions or list all of them.
      allow delete, list: if false;
    }
    
    match /correctionRequests/{requestId} {
      // Students can create their own correction requests.
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      
      // Students can view their own requests. Faculty and admins can view any request.
      // NOTE: This allows any faculty member to see any request. A more secure rule would limit this to the faculty teaching the specific course.
      allow get, list: if (isSignedIn() && isOwner(resource.data.studentId)) || isFacultyOrAnyAdmin();
      
      // Only faculty or admins can update (approve/reject) a request.
      allow update: if isFacultyOrAnyAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'resolverId', 'resolvedAt', 'resolverComments']);
      
      // Only the student who created it or an admin can delete a PENDING request.
      allow delete: if isAnyAdmin() || (isOwner(resource.data.studentId) && resource.data.status == 'pending');
    }

    match /helpdeskTickets/{ticketId} {
      // Students can create tickets for themselves, ensuring their info is correct.
      allow create: if isSignedIn() 
                      && request.resource.data.studentId == request.auth.uid
                      && request.resource.data.studentName == getUser(request.auth.uid).data.name;

      // Students can read their own tickets. Faculty/Admins can read all.
      allow get, list: if (isSignedIn() && resource.data.studentId == request.auth.uid) || isFacultyOrAnyAdmin();

      // Admins/Faculty can update to close the ticket.
      allow update: if isFacultyOrAnyAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'resolvedAt', 'resolvedBy']);

      // A student can delete their own open ticket. Admins can delete any.
      allow delete: if (isOwner(resource.data.studentId) && resource.data.status == 'open') || isAnyAdmin();
    }
  }
}
